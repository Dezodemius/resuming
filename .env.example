# Ollama (запускается на этом же сервере)
OLLAMA_URL=http://localhost:11434
# ВНИМАНИЕ: qwen2.5:14b требует ~10+ ГБ свободной RAM (без GPU).
# Если памяти меньше — llama-server убивает OOM-killer и сайт отдаёт 502.
# Для серверов с 8 ГБ RAM используйте qwen2.5:7b, с 4 ГБ — qwen2.5:3b.
OLLAMA_MODEL=qwen2.5:14b

# Telegram Login (создать бота через @BotFather)
# /newbot → получить токен → /setdomain → указать домен сервера
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_BOT_NAME=MyResumeBot

# Email (Яндекс SMTP — бесплатно)
# Яндекс: Настройки → Безопасность → Пароли приложений → создать пароль для почты
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your@yandex.ru
SMTP_PASS=app_password_here
SMTP_FROM=your@yandex.ru

# ЮKassa
YOKASSA_SHOP_ID=123456
YOKASSA_SECRET_KEY=live_...

# Яндекс OAuth (создать приложение: https://oauth.yandex.ru/client/new)
# Redirect URI: {APP_URL}/auth/yandex/callback
# Права: login:email + login:info
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Публичный URL (без слеша в конце)
APP_URL=https://your-domain.com
SECRET_KEY=your-random-secret-key-here-change-me
AI_CONCURRENCY=2   # max параллельных вызовов Ollama
LOG_LEVEL=INFO     # DEBUG / INFO / WARNING
